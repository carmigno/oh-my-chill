{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "template": "\u256d\u2500<#cfc1a9>{{ .UserName }}@{{ .HostName }}</>\u2500",
          "type": "session"
        },
        {
          "foreground": "#d29b5a",
          "style": "plain",
          "properties": {
            "style": "full"
          },
          "template": "<#d29b5a>[{{ .Path }}]</>",
          "type": "path"
        },
        {
          "foreground": "#c2562d",
          "style": "plain",
          "template": "<#c2562d>\u2500(</>#<#564a45>)</>",
          "type": "root"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#96a65e",
          "properties": {
            "fetch_package_manager": true,
            "npm_icon": " <#c2562d>\ue5fa</> ",
            "yarn_icon": " <#3b8e8c>\ue6a7</>"
          },
          "style": "plain",
          "template": "<#564a45>(</>{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}<#564a45>)</>",
          "type": "node"
        },
        {
          "foreground": "#d29b5a",
          "style": "plain",
          "template": "{{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "type": "python"
        },
        {
          "foreground": "#c2562d",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "java"
        },
        {
          "foreground": "#3b8e8c",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "dotnet"
        },
        {
          "foreground": "#3b8e8c",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "go"
        },
        {
          "foreground": "#c47e5b",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "rust"
        },
        {
          "foreground": "#3b8e8c",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "dart"
        },
        {
          "foreground": "#c2562d",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "angular"
        },
        {
          "foreground": "#c47e5b",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "aurelia"
        },
        {
          "foreground": "#cfc1a9",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}<#564a45>)</>",
          "type": "nx"
        },
        {
          "foreground": "#96a65e",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "julia"
        },
        {
          "foreground": "#c2562d",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "ruby"
        },
        {
          "foreground": "#3b8e8c",
          "style": "plain",
          "template": "<#564a45>(</>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#564a45>)</>",
          "type": "azfunc"
        },
        {
          "foreground": "#d29b5a",
          "style": "plain",
          "template": "<#564a45>(</>{{.Profile}}{{if .Region}}@{{.Region}}{{end}}<#564a45>)</>",
          "type": "aws"
        },
        {
          "foreground": "#3b8e8c",
          "style": "plain",
          "template": "<#564a45>(</>{{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}<#564a45>)</>",
          "type": "kubectl"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        },
        {
          "foreground": "#cfc1a9",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#564a45>[</>{{ .HEAD }}{{ if .Staging.Changed }}<#96a65e> \u25cf {{ .Staging.String }}</>{{ end }}{{ if .Working.Changed }}<#c2562d> \u25cf {{ .Working.String }}</>{{ end }}<#564a45>]</>",
          "type": "git"
        },
        {
          "foreground": "#cfc1a9",
          "foreground_templates": ["{{ if gt .Code 0 }}#c2562d{{ end }}"],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\ue285 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 1
}
